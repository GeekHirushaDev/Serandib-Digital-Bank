# Copy this file to ".env" and fill in your OWN credentials.
# The .env file is git-ignored and must never be committed or shared.

# --- Commercial Bank login ---
COMBANK_USERNAME=your_combank_username
COMBANK_PASSWORD=your_combank_password

# --- Gmail (for automatic OTP retrieval over IMAP) ---
# Use a Google "App Password" (16 chars), NOT your normal Gmail password.
# Create one at: https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Optional: set to "true" to run the browser hidden (no window).
# Leave as false for the first runs so you can watch the login happen.
HEADLESS=false
